{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "name": { "type": "string", "description": "User's display name" },
        "isPremium": { "type": "boolean", "description": "Whether the user has premium access" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "name"]
    },
    "Post": {
      "title": "Post",
      "description": "A community post shared by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "number" },
        "likes": { "type": "number" }
      },
      "required": ["userId", "userName", "content", "createdAt"]
    },
    "Plan": {
      "title": "Plan",
      "description": "A personalized AI-generated workout and nutrition plan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workoutPlan": { "type": "array" },
        "nutritionPlan": { "type": "object" },
        "tips": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "workoutPlan", "nutritionPlan", "createdAt"]
    },
    "Workout": {
      "title": "Workout",
      "description": "A logged workout session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "exercises": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "exercises", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community posts"
    },
    "/plans/{planId}": {
      "schema": "Plan",
      "description": "AI-generated plans"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Logged workout sessions"
    }
  }
}
